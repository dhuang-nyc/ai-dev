ANTHROPIC_API_KEY=
SECRET_KEY=change-me
DEBUG=True
POSTGRES_DB=aidev
POSTGRES_USER=aidev
POSTGRES_PASSWORD=aidev
POSTGRES_HOST=db
REDIS_URL=redis://redis:6379/0
DJANGO_SUPERUSER_PASSWORD=admin

# GitHub integration (optional) — repos are created when a project moves to In Progress
# GITHUB_TOKEN requires the `repo` scope (classic) or Contents+Administration write (fine-grained)
GITHUB_TOKEN=
GITHUB_USERNAME=        # your GitHub username; used to detect existing repos
GITHUB_ORG=            # set this to create repos under an org instead of your personal account

# Dev agent settings — required for automated PR workflow
DEV_GITHUB_TOKEN=      # token for dev agents (repo write scope)
DEV_GIT_NAME=Dev Agent # git commit author name
DEV_GIT_EMAIL=         # git commit author email
WORKSPACES_BASE=/workspaces
