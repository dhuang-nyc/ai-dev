ANTHROPIC_API_KEY=
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True                  # set False in production
ALLOWED_HOSTS=*             # set to your domain in production e.g. capyai.daisyhuang.dev
POSTGRES_DB=aidev
POSTGRES_USER=aidev
POSTGRES_PASSWORD=aidev     # use a strong password in production
POSTGRES_HOST=db
REDIS_URL=redis://redis:6379/0
DJANGO_SUPERUSER_PASSWORD=admin  # change in production
APP_BASE_URL=               # public URL of this app e.g. https://capyai.daisyhuang.dev (used to register webhooks)

# Flower basic auth (production) — generate with: echo $(htpasswd -nB admin) | sed -e s/\\$/\\$\\$/g
FLOWER_AUTH_USERS=

# GitHub integration (optional) — repos are created when a project moves to In Progress
# GITHUB_TOKEN requires the `repo` scope (classic) or Contents+Administration write (fine-grained)
GITHUB_TOKEN=
GITHUB_USERNAME=        # your GitHub username; used to detect existing repos
GITHUB_ORG=             # set this to create repos under an org instead of your personal account
GITHUB_WEBHOOK_SECRET=  # random secret shared with GitHub for webhook signature verification

# Dev agent settings — required for automated PR workflow
DEV_GITHUB_TOKEN=       # token for dev agents (repo write scope)
DEV_GITHUB_USERNAME=    # GitHub username of the dev agent bot (added as write collaborator on each repo)
DEV_GIT_NAME=Dev Agent  # git commit author name
DEV_GIT_EMAIL=          # git commit author email
WORKSPACES_BASE=/workspaces
